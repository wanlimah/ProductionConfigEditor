    <Window x:Class="DigitalProductionConfigEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DigitalProductionConfigEditor.ViewModels"
        xmlns:conv="clr-namespace:DigitalProductionConfigEditor.Converters"
        Title="ProductionConfigEditor" Height="600" Width="800"
        Icon="app_icon.ico"
        WindowState="Maximized">

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
        <conv:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
        <conv:XmlNodeToDisplayConverter x:Key="XmlNodeToDisplayConverter"/>
    </Window.Resources>

    <!-- Remove the DataContext declaration from XAML since it's set in code-behind -->
    <!--<Window.DataContext>
        <vm:WizardViewModel />
    </Window.DataContext>-->

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="DodgerBlue" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Production Config Editor" 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="Manage XML Configuration Packages" 
                                   FontSize="12" 
                                   Foreground="White" Opacity="0.9"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" 
                               Text="v1.2.0" 
                               FontSize="12" 
                               Foreground="White" 
                               Opacity="0.8" 
                               VerticalAlignment="Top" 
                               Margin="0,2,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Wizard Content -->
        <ContentControl Grid.Row="1" x:Name="WizardContent" Margin="0,0,0,10" />

        <!-- Status Message -->
        <TextBlock Grid.Row="2" 
                   Text="{Binding StatusMessage}" 
                   Foreground="Blue" FontWeight="SemiBold" 
                   Margin="0,10,0,10" 
                   TextWrapping="Wrap"/>

        <!-- Navigation Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Margin="0,10,0,0">
            <Button Content="❓ Help" Click="OnHelpClick" 
                    Margin="5" Padding="10,5" Background="LightGoldenrodYellow"
                    ToolTip="Show quick start guide and instructions"/>
            <Button Content="📖 Function Guide" Click="OnFunctionGuideClick" 
                    Margin="5" Padding="10,5" Background="LightSkyBlue"
                    ToolTip="View detailed function reference (Pending Update)"/>
            <Button Content="🏠 Return to Start" Click="OnReturnToStartClick" 
                    Margin="5" Padding="10,5" Background="LightSalmon"
                    ToolTip="Return to Step 1 to add more configurations or start new"/>
            <Button Content="📄 New" Click="OnNewXmlClick" 
                    Margin="5" Padding="10,5" Background="LightCyan"
                    ToolTip="Create a new blank XML configuration"/>
            <Button Content="📂 Open" Click="OnOpenXmlClick" 
                    Margin="5" Padding="10,5" Background="LightYellow"
                    ToolTip="Open an existing XML configuration"/>
            <Button Content="🔄 Reload Master" Click="OnReloadXmlClick" 
                    Margin="5" Padding="10,5" Background="LightBlue"
                    ToolTip="Reload the master template XML"/>
            <Button Content="🛠️ Edit Master" Click="OnEditMasterClick"
                    Margin="5" Padding="10,5" Background="Plum"
                    ToolTip="Unlock and edit the Master Template (Developers Only)"/>
            <Button Content="⬅ Back" Click="OnBackClick" 
                    Margin="5" Padding="10,5"/>
            <Button Content="Next ➡" Click="OnNextClick" 
                    Margin="5" Padding="10,5"/>
            <Button Content="💾 Save" Click="OnSaveXmlClick" 
                    Margin="5" Padding="10,5" Background="LightGreen"
                    ToolTip="Save current XML configuration"/>
            <Button Content="💾 Save As..." Click="OnSaveAsXmlClick" 
                    Margin="5" Padding="10,5" Background="PaleGreen"
                    ToolTip="Save XML configuration to a new file"/>
        </StackPanel>
    </Grid>
</Window>
