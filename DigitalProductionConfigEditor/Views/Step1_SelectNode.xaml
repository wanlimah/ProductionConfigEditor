<UserControl x:Class="DigitalProductionConfigEditor.Views.Step1_SelectNode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DigitalProductionConfigEditor.Converters">
    <UserControl.Resources>
        <converters:XmlNodeToDisplayConverter x:Key="XmlNodeConverter"/>
        <converters:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="PcbStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewPcbFormatConfig, Converter={StaticResource NotNullToBoolConverter}}" Value="True">
                    <Setter Property="Foreground" Value="Blue"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputValStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewInputValidationConfigs, Converter={StaticResource NotNullToBoolConverter}}" Value="True">
                    <Setter Property="Foreground" Value="DarkGoldenrod"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DcContactStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewDcContactModeSettingOverwrite, Converter={StaticResource NotNullToBoolConverter}}" Value="True">
                    <Setter Property="Foreground" Value="#BF360C"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MailConfigStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding NewMailConfig, Converter={StaticResource NotNullToBoolConverter}}" Value="True">
                    <Setter Property="Foreground" Value="#1565C0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Master Template Nodes -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Step 1: Build Your Configuration" 
                           FontWeight="Bold" FontSize="16" Margin="0,0,0,20"/>

                <!-- Production User Configs Section -->
                <Border BorderBrush="Purple" 
                        BorderThickness="2" 
                        Background="Lavender" 
                        Padding="15" 
                        Margin="0,0,0,10" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="📋 Production User Configs" 
                                   FontWeight="Bold" 
                                   FontSize="14"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="Select configuration nodes to add to your new XML" 
                                   FontSize="12"
                                   Foreground="DarkSlateBlue"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="🔒 Safety: All packages will have enable=FALSE by default" 
                                   FontSize="11"
                                   Foreground="Green"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"
                                   TextWrapping="Wrap"/>
                        <!-- Test-type badge legend -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Test:" FontSize="10" Foreground="DarkSlateBlue" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Border Background="#00BCD4" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                <TextBlock Text="ALL" FontSize="9" FontWeight="Bold" Foreground="Black"/>
                            </Border>
                            <Border Background="#FFEB3B" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                <TextBlock Text="RF1" FontSize="9" FontWeight="Bold" Foreground="Black"/>
                            </Border>
                            <Border Background="#FF9800" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                <TextBlock Text="RF2" FontSize="9" FontWeight="Bold" Foreground="Black"/>
                            </Border>
                            <Border Background="#F06292" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                <TextBlock Text="NFR" FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <Border Background="#64B5F6" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                <TextBlock Text="TDG" FontSize="9" FontWeight="Bold" Foreground="Black"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bulk Selection Actions for Production Configs -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="☑ Select All" 
                            Width="95" Height="26" 
                            Background="LightBlue"
                            Click="OnSelectAllConfigClick"
                            Margin="0,0,5,0"
                            ToolTip="Select all configuration nodes"/>
                    <Button Content="☐ Deselect All" 
                            Width="95" Height="26" 
                            Background="LightGray"
                            Click="OnDeselectAllConfigClick"
                            Margin="0,0,10,0"
                            ToolTip="Deselect all configuration nodes"/>
                    <Button Content="➕ Add Selected" 
                            Width="110" Height="26" 
                            Background="LightGreen"
                            FontWeight="SemiBold"
                            Click="OnAddSelectedConfigClick"
                            ToolTip="Add all selected configuration nodes to your XML"/>
                </StackPanel>

                <!-- Missing doc-range warning banner — shown when any element has no Google Sheet link -->
                <Border Background="#FFF3CD" BorderBrush="#FF9800" BorderThickness="1" CornerRadius="3"
                        Padding="10,6" Margin="0,0,0,8"
                        Visibility="{Binding HasMissingDocRangeWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="#7B4800"
                                   Text="⚠️  Developer action required — Google Sheet documentation is out of date"/>
                        <TextBlock FontSize="10" Foreground="#7B4800" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="{Binding MissingDocRangeWarning}"/>
                        <TextBlock FontSize="10" Foreground="#7B4800" Margin="0,4,0,0" FontStyle="Italic"
                                   Text="Steps: (1) Add the row to the Google Sheet  (2) Create a Named Range using the element name  (3) Set docRange=&quot;ElementName&quot; in Master_ProductionUserConfig.xml"/>
                    </StackPanel>
                </Border>

                <!-- Master Configuration Nodes List -->
                <ItemsControl ItemsSource="{Binding MasterConfigNodeItems}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" 
                                    BorderThickness="1" 
                                    Background="White" 
                                    Padding="10" 
                                    Margin="0,5,0,5" 
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Checkbox for selection -->
                                    <CheckBox Grid.Column="0" 
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"
                                              ToolTip="Select this configuration node"/>

                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding NodeName}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="{Binding SupportedTestsBadgeColor}"
                                                    CornerRadius="3"
                                                    Padding="5,1"
                                                    Margin="7,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasSupportedTests, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    ToolTip="Supported test type: the feature is available for this test category">
                                                <TextBlock Text="{Binding SupportedTests}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding SupportedTestsTextColor}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="Gray">
                                            <Run Text="{Binding ItemCount, StringFormat='{}{0} items', Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                            Content="➕ Add" 
                                            Padding="10,5"
                                            MinWidth="75"
                                            Width="75"
                                            Background="LightGreen"
                                            Tag="{Binding ConfigNode}"
                                            Click="OnAddConfigurationClick"/>

                                    <!-- Doc link button — visible only when docUrl is set in the XML root -->
                                    <Button Grid.Column="3"
                                            Content="📖"
                                            FontSize="14"
                                            Padding="6,4"
                                            Margin="5,0,0,0"
                                            Background="LightYellow"
                                            BorderBrush="#CCC"
                                            Tag="{Binding DocUrl}"
                                            Click="OnOpenDocClick"
                                            Visibility="{Binding HasDocUrl, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            ToolTip="Open Google Sheets documentation for this element"/>

                                    <!-- Missing doc warning — visible when docUrl is set but this element has no docRange -->
                                    <Border Grid.Column="3"
                                            Background="#FFF3CD" BorderBrush="#FF9800" BorderThickness="1"
                                            CornerRadius="3" Padding="5,2" Margin="5,0,0,0"
                                            Visibility="{Binding IsDocRangeMissing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            ToolTip="No Google Sheet link. Add a row for this element, create a Named Range matching its element name, then set docRange in Master_ProductionUserConfig.xml.">
                                        <TextBlock Text="⚠️ No Doc" FontSize="9" FontWeight="Bold" Foreground="#7B4800"/>
                                    </Border>

                                    <!-- No Data badge — docRange is set to NO_DATA, sheet entry pending -->
                                    <Border Grid.Column="3"
                                            Background="#E0E0E0" BorderBrush="#9E9E9E" BorderThickness="1"
                                            CornerRadius="3" Padding="5,2" Margin="5,0,0,0"
                                            Visibility="{Binding IsDocRangeNoData, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            ToolTip="Documentation not yet available. To add it: create a row in the Google Sheet, create a Named Range using this element name, then update docRange in Master_ProductionUserConfig.xml.">
                                        <TextBlock Text="No Data" FontSize="9" FontWeight="Bold" Foreground="#424242"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Developer Validation Unlock Section -->
                <StackPanel Margin="0,10,0,10">
                    <Button x:Name="UnlockDeveloperButton"
                            Content="🔧 Show Developer Validation Config"
                            Click="OnUnlockDeveloperClick"
                            Height="30"
                            Background="PeachPuff"
                            BorderBrush="DarkOrange"
                            FontWeight="SemiBold"
                            ToolTip="Click to unlock developer validation configuration"/>

                    <StackPanel x:Name="DeveloperPasswordPanel" Visibility="Collapsed" Margin="0,5,0,0" Orientation="Horizontal">
                        <TextBlock Text="Passkey:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <PasswordBox x:Name="DeveloperPasskeyBox" Width="100" Margin="0,0,5,0"/>
                        <Button Content="Unlock" Click="OnVerifyDeveloperPasskeyClick" Background="LightGreen" Padding="10,0"/>
                        <TextBlock x:Name="DeveloperPasskeyError" Text="Invalid Passkey" Foreground="Red" Margin="5,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>

                <!-- Developer Validation Config Section (Initially Collapsed) -->
                <StackPanel x:Name="DeveloperConfigPanel" Visibility="Collapsed">
                    <Border BorderBrush="DarkOrange" 
                            BorderThickness="2" 
                            Background="PeachPuff" 
                            Padding="15" 
                            Margin="0,10,0,10" 
                            CornerRadius="5">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="🔧 Developer Validation Config" 
                                           FontWeight="Bold" 
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                                <Border Background="#64B5F6" CornerRadius="3" Padding="5,1"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        ToolTip="This section is only applicable to TDG test type">
                                    <TextBlock Text="TDG" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Developer validation and equipment checks" 
                                       FontSize="12"
                                       Foreground="DarkOrange"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Bulk Selection Actions for Developer Validation Configs -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="☑ Select All" 
                                Width="95" Height="26" 
                                Background="LightBlue"
                                Click="OnSelectAllDevValidationClick"
                                Margin="0,0,5,0"
                                ToolTip="Select all developer validation nodes"/>
                        <Button Content="☐ Deselect All" 
                                Width="95" Height="26" 
                                Background="LightGray"
                                Click="OnDeselectAllDevValidationClick"
                                Margin="0,0,10,0"
                                ToolTip="Deselect all developer validation nodes"/>
                        <Button Content="➕ Add Selected" 
                                Width="110" Height="26" 
                                Background="LightGreen"
                                FontWeight="SemiBold"
                                Click="OnAddSelectedDevValidationClick"
                                ToolTip="Add all selected developer validation nodes to your XML"/>
                    </StackPanel>

                    <!-- Developer Validation Nodes List -->
                    <ItemsControl ItemsSource="{Binding MasterDevValidationNodeItems}" Margin="0,0,0,20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" 
                                        BorderThickness="1" 
                                        Background="White" 
                                        Padding="10" 
                                        Margin="0,5,0,5" 
                                        CornerRadius="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Checkbox for selection -->
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0"
                                                  ToolTip="Select this developer validation node"/>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding NodeName}" 
                                                           FontWeight="SemiBold" 
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="{Binding SupportedTestsBadgeColor}"
                                                        CornerRadius="3"
                                                        Padding="5,1"
                                                        Margin="7,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding HasSupportedTests, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        ToolTip="Supported test type: the feature is available for this test category">
                                                    <TextBlock Text="{Binding SupportedTests}"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding SupportedTestsTextColor}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock FontSize="11" Foreground="Gray">
                                                <Run Text="{Binding ItemCount, StringFormat='{}{0} items', Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="2" 
                                                Content="➕ Add" 
                                                Padding="10,5"
                                                MinWidth="75"
                                                Width="75"
                                                Background="LightGreen"
                                                Tag="{Binding ConfigNode}"
                                                Click="OnAddDeveloperValidationClick"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- PCB Format Config Section -->
                <Border BorderBrush="DarkBlue" 
                        BorderThickness="2" 
                        Background="LightBlue" 
                        Padding="15" 
                        Margin="0,10,0,10" 
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="🔲 PCB Format Config" 
                                   FontWeight="Bold" 
                                   FontSize="14"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="PCB panel and island configuration" 
                                   FontSize="12"
                                   Foreground="DarkBlue"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="⚠️ Important: Add PCB Config ONCE, then Edit to add islands!" 
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="Red"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- PCB Format Config Item -->
                <Border BorderBrush="Gray" 
                        BorderThickness="1" 
                        Background="White" 
                        Padding="10" 
                        Margin="0,5,0,20" 
                        CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Checkbox (always unchecked for single item) -->
                        <CheckBox Grid.Column="0" 
                                  IsChecked="False"
                                  IsEnabled="False"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  ToolTip="PCB Format Config"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="PCB Format Config" 
                                       FontWeight="SemiBold" 
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBlock FontSize="11" Foreground="Gray"
                                       Text="1 items"/>
                        </StackPanel>

                        <Button Grid.Column="2" 
                                Content="➕ Add" 
                                Padding="10,5"
                                MinWidth="75"
                                Width="75"
                                Background="LightGreen"
                                Click="OnAddPcbFormatConfigClick"
                                ToolTip="Add PCB Format Config ONCE. After adding, use the Edit button to manage islands."/>
                    </Grid>
                </Border>

                <!-- Input Validation Configs Section (left panel info box) -->
                <Border BorderBrush="#F57F17"
                        BorderThickness="2"
                        Background="#FFF8E1"
                        Padding="15"
                        Margin="0,10,0,10"
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="🔍 Input Validation Configs"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,5"/>
                        <TextBlock FontSize="12"
                                   Foreground="#5D4037"
                                   TextWrapping="Wrap">
                            Define regex validation patterns for Device IDs, Loadboard IDs, and Sublot IDs.
                            Add this section once, then use Edit to manage entries.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- InputValidationConfigs single-item row (left panel) -->
                <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Background="White"
                        Padding="10"
                        Margin="0,5,0,20"
                        CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="False"
                                  IsEnabled="False"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Input Validation Configs"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBlock FontSize="11" Foreground="Gray"
                                       Text="1 section (multiple TestConfig entries)"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="➕ Add"
                                Padding="10,5"
                                MinWidth="75"
                                Width="75"
                                Background="LightGreen"
                                Click="OnAddInputValidationConfigsClick"
                                ToolTip="Add InputValidationConfigs section. Use Edit to add entries."/>
                    </Grid>
                </Border>

                <!-- DC Contact Mode Setting Overwrite Section -->
                <Border BorderBrush="#BF360C"
                        BorderThickness="2"
                        Background="#FBE9E7"
                        Padding="15"
                        Margin="0,10,0,10"
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="⚡ DC Contact Mode Setting Overwrite"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,5"/>
                        <TextBlock FontSize="12"
                                   Foreground="#BF360C"
                                   TextWrapping="Wrap">
                            Per-pin electrical parameters for DC Open/Short contact testing (FORCEV / FORCEI modes).
                            Add this section once, then use Edit to manage Pin entries.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- DC Contact Mode single-item row -->
                <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Background="White"
                        Padding="10"
                        Margin="0,5,0,20"
                        CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="False"
                                  IsEnabled="False"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="DC_CONTACT_MODE_SETTING_OVERWRITE"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBlock FontSize="11" Foreground="Gray"
                                       Text="1 section (Pin entries + Delayms)"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="➕ Add"
                                Padding="10,5"
                                MinWidth="75"
                                Width="75"
                                Background="LightGreen"
                                Click="OnAddDcContactModeClick"
                                ToolTip="Add DC_CONTACT_MODE_SETTING_OVERWRITE section. Use Edit to manage Pin entries."/>
                    </Grid>
                </Border>

                <!-- Mail Config Section -->
                <Border BorderBrush="#1565C0"
                        BorderThickness="2"
                        Background="#E3F2FD"
                        Padding="15"
                        Margin="0,10,0,10"
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="✉ Mail Config"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,5"/>
                        <TextBlock FontSize="12"
                                   Foreground="#1565C0"
                                   TextWrapping="Wrap">
                            Email notification endpoint for automated Clotho test reports.
                            Add this section once, then use Edit to update addresses and API URL.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Mail Config single-item row -->
                <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Background="White"
                        Padding="10"
                        Margin="0,5,0,20"
                        CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="False"
                                  IsEnabled="False"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="MailConfig"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBlock FontSize="11" Foreground="Gray"
                                       Text="1 section (APIURL, RecipientEmail, ReplyTo)"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="➕ Add"
                                Padding="10,5"
                                MinWidth="75"
                                Width="75"
                                Background="LightGreen"
                                Click="OnAddMailConfigClick"
                                ToolTip="Add MailConfig section. Use Edit to set API URL and recipients."/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT PANEL: Your New Configuration -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border BorderBrush="Green" 
                        BorderThickness="2" 
                        Background="Honeydew" 
                        Padding="15" 
                        Margin="0,41,0,10" 
                        CornerRadius="5">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📝 Your New Configuration" 
                                           FontWeight="Bold" 
                                           FontSize="14"
                                           Margin="0,0,0,5"/>
                                <TextBlock FontSize="12" Foreground="DarkGreen" TextWrapping="Wrap">
                                    <Run Text="{Binding NewConfigurationNodes.Count, StringFormat='{}{0} production config(s)', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Create New Config Button (Visible only when Editing Master) -->
                            <Button Grid.Column="1"
                                    Content="➕ Create New" 
                                    Padding="10,5"
                                    Background="LightSkyBlue"
                                    FontWeight="SemiBold"
                                    Visibility="{Binding IsEditingMaster, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Click="OnCreateNewConfigClick"
                                    ToolTip="Create a completely new configuration node (Edit Master Mode)"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Production User Configuration Nodes List -->
                <TextBlock Text="Production User Configs:" 
                           FontWeight="SemiBold" 
                           FontSize="12" 
                           Margin="0,10,0,5"/>
                <ItemsControl ItemsSource="{Binding NewConfigurationNodes}" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Green" 
                                    BorderThickness="1" 
                                    Background="White" 
                                    Padding="10" 
                                    Margin="0,5,0,5" 
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13"
                                                   Margin="0,0,0,5"
                                                   Foreground="DarkGreen"/>
                                        <TextBlock FontSize="11" Foreground="Gray">
                                            <Run Text="{Binding ChildNodes.Count, StringFormat='{}{0} items', Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <Button Grid.Column="1" 
                                            Content="✏ Edit" 
                                            Padding="10,5"
                                            MinWidth="80"
                                            Width="80"
                                            Background="LightYellow"
                                            Tag="{Binding}"
                                            Click="OnEditConfigurationClick"/>

                                    <Button Grid.Column="3" 
                                            Content="🗑 Delete" 
                                            Padding="10,5"
                                            MinWidth="80"
                                            Width="80"
                                            Background="LightCoral"
                                            Tag="{Binding}"
                                            Click="OnDeleteConfigurationClick"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Developer Validation Configuration Nodes List (only visible when developer mode is unlocked) -->
                <StackPanel Visibility="{Binding IsDeveloperModeUnlocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Developer Validation Configs:" 
                               FontWeight="SemiBold" 
                               FontSize="12" 
                               Margin="0,10,0,5"/>
                    <ItemsControl ItemsSource="{Binding NewDeveloperValidationNodes}" Margin="0,0,0,20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="DarkOrange" 
                                        BorderThickness="1" 
                                        Background="White" 
                                        Padding="10" 
                                        Margin="0,5,0,5" 
                                        CornerRadius="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="13"
                                                       Margin="0,0,0,5"
                                                       Foreground="DarkOrange"/>
                                            <TextBlock FontSize="11" Foreground="Gray">
                                                <Run Text="{Binding ChildNodes.Count, StringFormat='{}{0} items', Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="1" 
                                                Content="✏ Edit" 
                                                Padding="10,5"
                                                MinWidth="80"
                                                Width="80"
                                                Background="LightYellow"
                                                Tag="{Binding}"
                                                Click="OnEditDeveloperValidationClick"/>

                                        <Button Grid.Column="3" 
                                                Content="🗑 Delete" 
                                                Padding="10,5"
                                                MinWidth="80"
                                                Width="80"
                                                Background="LightCoral"
                                                Tag="{Binding}"
                                                Click="OnDeleteDeveloperValidationClick"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- PCB Format Config — only visible once added -->
                <StackPanel Visibility="{Binding NewPcbFormatConfig, Converter={StaticResource NotNullToVisibilityConverter}}">
                    <TextBlock Text="PCB Format Config:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,10,0,5"/>
                    <Border BorderBrush="Orange"
                            BorderThickness="2"
                            Background="LightYellow"
                            Padding="10"
                            Margin="0,5,0,10"
                            CornerRadius="3">
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="DarkOrange" TextWrapping="Wrap" Margin="0,0,0,5">
                                💡 PCB Quick Tip:
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="DarkOrange" TextWrapping="Wrap">
                                • Click ✏ Edit to add/modify islands (most common)
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="DarkOrange" TextWrapping="Wrap">
                                • Each product = Different island inside same PCB
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="DarkBlue"
                            BorderThickness="1"
                            Background="White"
                            Padding="10"
                            Margin="0,5,0,5"
                            CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5" Foreground="DarkBlue">
                                    <Run Text="PcbFormatConfig"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Style="{StaticResource PcbStatusTextStyle}">
                                    <Run Text="{Binding NewPcbFormatConfig, Converter={StaticResource XmlNodeConverter}, StringFormat='Status: {0}', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✏ Edit" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightYellow" Click="OnEditPcbFormatConfigClick"
                                    ToolTip="Click here to add/edit islands. Each island = one product variant."/>
                            <Button Grid.Column="3" Content="🗑 Delete" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightCoral" Click="OnDeletePcbFormatConfigClick"
                                    ToolTip="Remove entire PCB Format Config section"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Input Validation Configs — only visible once added -->
                <StackPanel Visibility="{Binding NewInputValidationConfigs, Converter={StaticResource NotNullToVisibilityConverter}}">
                    <TextBlock Text="Input Validation Configs:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,15,0,5"/>
                    <Border BorderBrush="Orange"
                            BorderThickness="2"
                            Background="LightYellow"
                            Padding="10"
                            Margin="0,5,0,10"
                            CornerRadius="3">
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="DarkGoldenrod" TextWrapping="Wrap" Margin="0,0,0,4">
                                💡 Input Validation Quick Tip:
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="DarkGoldenrod" TextWrapping="Wrap">
                                • Click ✏ Edit to manage TestConfig entries (Add / Delete / modify patterns)
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="DarkGoldenrod" TextWrapping="Wrap">
                                • Global = applies to all packages  |  Per-Package = targeted to a specific tag
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#F57F17"
                            BorderThickness="1"
                            Background="White"
                            Padding="10"
                            Margin="0,5,0,5"
                            CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5" Foreground="DarkGoldenrod">
                                    <Run Text="InputValidationConfigs"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Style="{StaticResource InputValStatusTextStyle}">
                                    <Run Text="{Binding NewInputValidationConfigs, Converter={StaticResource XmlNodeConverter}, StringFormat='Status: {0}', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✏ Edit" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightYellow" Click="OnEditInputValidationConfigsClick"
                                    ToolTip="Open the editor to add, modify or delete TestConfig entries"/>
                            <Button Grid.Column="3" Content="🗑 Delete" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightCoral" Click="OnDeleteInputValidationConfigsClick"
                                    ToolTip="Remove the entire InputValidationConfigs section"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- DC Contact Mode Setting Overwrite — only visible once added -->
                <StackPanel Visibility="{Binding NewDcContactModeSettingOverwrite, Converter={StaticResource NotNullToVisibilityConverter}}">
                    <TextBlock Text="DC Contact Mode Setting Overwrite:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,15,0,5"/>
                    <Border BorderBrush="#BF360C"
                            BorderThickness="2"
                            Background="#FBE9E7"
                            Padding="10"
                            Margin="0,5,0,10"
                            CornerRadius="3">
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="#BF360C" TextWrapping="Wrap" Margin="0,0,0,4">
                                💡 DC Contact Mode Quick Tip:
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#BF360C" TextWrapping="Wrap">
                                • Click ✏ Edit to add/modify Pin entries (FORCEV or FORCEI) and set Delayms
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#BF360C" TextWrapping="Wrap">
                                • FORCEV pins (Vdd, Vbatt): VSet + ISet  |  FORCEI pins (Vio): VSetHi/Lo + ISource
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#BF360C"
                            BorderThickness="1"
                            Background="White"
                            Padding="10"
                            Margin="0,5,0,5"
                            CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5" Foreground="#BF360C">
                                    <Run Text="DC_CONTACT_MODE_SETTING_OVERWRITE"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Style="{StaticResource DcContactStatusTextStyle}">
                                    <Run Text="{Binding NewDcContactModeSettingOverwrite, Converter={StaticResource XmlNodeConverter}, StringFormat='Status: {0}', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✏ Edit" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightYellow" Click="OnEditDcContactModeClick"
                                    ToolTip="Open the editor to manage Pin entries and Delayms"/>
                            <Button Grid.Column="3" Content="🗑 Delete" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightCoral" Click="OnDeleteDcContactModeClick"
                                    ToolTip="Remove the entire DC_CONTACT_MODE_SETTING_OVERWRITE section"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Mail Config — only visible once added -->
                <StackPanel Visibility="{Binding NewMailConfig, Converter={StaticResource NotNullToVisibilityConverter}}">
                    <TextBlock Text="Mail Config:"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,15,0,5"/>
                    <Border BorderBrush="#1565C0"
                            BorderThickness="2"
                            Background="#E3F2FD"
                            Padding="10"
                            Margin="0,5,0,10"
                            CornerRadius="3">
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1565C0" TextWrapping="Wrap" Margin="0,0,0,4">
                                💡 Mail Config Quick Tip:
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#1565C0" TextWrapping="Wrap">
                                • Click ✏ Edit to set the API URL, recipient addresses, and reply-to address
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#1565C0" TextWrapping="Wrap">
                                • Separate multiple recipients with a comma ( , )
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border BorderBrush="#1565C0"
                            BorderThickness="1"
                            Background="White"
                            Padding="10"
                            Margin="0,5,0,5"
                            CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5" Foreground="#1565C0">
                                    <Run Text="MailConfig"/>
                                </TextBlock>
                                <TextBlock FontSize="11" Style="{StaticResource MailConfigStatusTextStyle}">
                                    <Run Text="{Binding NewMailConfig, Converter={StaticResource XmlNodeConverter}, StringFormat='Status: {0}', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✏ Edit" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightYellow" Click="OnEditMailConfigClick"
                                    ToolTip="Edit APIURL, RecipientEmail and ReplyTo fields"/>
                            <Button Grid.Column="3" Content="🗑 Delete" Padding="10,5" MinWidth="80" Width="80"
                                    Background="LightCoral" Click="OnDeleteMailConfigClick"
                                    ToolTip="Remove the entire MailConfig section"/>
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
