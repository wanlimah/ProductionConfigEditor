<UserControl x:Class="DigitalProductionConfigEditor.Views.Step3_ReviewAndSave"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DigitalProductionConfigEditor.Converters">
    <UserControl.Resources>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Step 3: Review Your Configuration" 
                       FontWeight="Bold" FontSize="16" Margin="0,0,0,20"/>

            <!-- Summary Info -->
            <Border Background="LightGreen" 
                    BorderBrush="Green" 
                    BorderThickness="2" 
                    CornerRadius="5" 
                    Padding="15" 
                    Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="✅ Configuration Summary" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <TextBlock>
                        <Run Text="Production User Configs: "/>
                        <Run Text="{Binding NewConfigurationNodes.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Developer Validation Configs: "/>
                        <Run Text="{Binding NewDeveloperValidationNodes.Count, Mode=OneWay, FallbackValue=0}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Total Configurations: "/>
                        <Run Text="{Binding AllEditableConfigurationNodes.Count, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Total Packages: "/>
                        <Run Text="{Binding PackageNodes.Count, Mode=OneWay}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Visibility="{Binding NewPcbFormatConfig, Converter={StaticResource NotNullToVisibilityConverter}}">
                        <Run Text="PCB Format Config: "/>
                        <Run Text="✅ Added" FontWeight="Bold" Foreground="Green"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Production User Configurations -->
            <TextBlock Text="📋 Production User Configurations:" 
                       FontWeight="Bold" FontSize="14" Margin="0,0,0,10"
                       Foreground="DarkGreen"/>

            <ItemsControl ItemsSource="{Binding NewConfigurationNodes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="WhiteSmoke" 
                                BorderBrush="Green" 
                                BorderThickness="2" 
                                CornerRadius="3" 
                                Padding="10" 
                                Margin="0,0,0,10">
                            <StackPanel>
                                <!-- Configuration Name with Badge -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Border Background="LightGreen" 
                                            CornerRadius="3" 
                                            Padding="4,2" 
                                            Margin="0,0,8,0">
                                        <TextBlock Text="PROD" 
                                                   FontSize="9" 
                                                   FontWeight="Bold" 
                                                   Foreground="DarkGreen"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="Bold" 
                                               FontSize="13"
                                               Foreground="DarkGreen"/>
                                </StackPanel>
                                
                                <!-- Package Count -->
                                <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,5">
                                    <Run Text="{Binding ChildNodes.Count, StringFormat='{}{0} package(s)', Mode=OneWay}"/>
                                </TextBlock>
                                
                                <!-- Package List -->
                                <ItemsControl ItemsSource="{Binding ChildNodes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" 
                                                    BorderBrush="LightGray" 
                                                    BorderThickness="1" 
                                                    Padding="5" 
                                                    Margin="5,2,0,2">
                                                <TextBlock Text="{Binding OuterXml}" 
                                                           FontSize="10" 
                                                           FontFamily="Consolas"
                                                           Foreground="DarkSlateGray"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Developer Validation Configurations -->
            <TextBlock Text="🔧 Developer Validation Configurations:" 
                       FontWeight="Bold" FontSize="14" Margin="0,15,0,10"
                       Foreground="DarkOrange"/>

            <ItemsControl ItemsSource="{Binding NewDeveloperValidationNodes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="WhiteSmoke" 
                                BorderBrush="DarkOrange" 
                                BorderThickness="2" 
                                CornerRadius="3" 
                                Padding="10" 
                                Margin="0,0,0,10">
                            <StackPanel>
                                <!-- Configuration Name with Badge -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Border Background="PeachPuff" 
                                            CornerRadius="3" 
                                            Padding="4,2" 
                                            Margin="0,0,8,0">
                                        <TextBlock Text="DEV" 
                                                   FontSize="9" 
                                                   FontWeight="Bold" 
                                                   Foreground="DarkOrange"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="Bold" 
                                               FontSize="13"
                                               Foreground="DarkOrange"/>
                                </StackPanel>
                                
                                <!-- Package Count -->
                                <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,5">
                                    <Run Text="{Binding ChildNodes.Count, StringFormat='{}{0} package(s)', Mode=OneWay}"/>
                                </TextBlock>
                                
                                <!-- Package List -->
                                <ItemsControl ItemsSource="{Binding ChildNodes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" 
                                                    BorderBrush="LightGray" 
                                                    BorderThickness="1" 
                                                    Padding="5" 
                                                    Margin="5,2,0,2">
                                                <TextBlock Text="{Binding OuterXml}" 
                                                           FontSize="10" 
                                                           FontFamily="Consolas"
                                                           Foreground="DarkSlateGray"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- PCB Format Config (if present) -->
            <Border Visibility="{Binding NewPcbFormatConfig, Converter={StaticResource NotNullToVisibilityConverter}}"
                    Background="WhiteSmoke" 
                    BorderBrush="DarkBlue" 
                    BorderThickness="2" 
                    CornerRadius="3" 
                    Padding="10" 
                    Margin="0,15,0,10">
                <StackPanel>
                    <TextBlock Text="🔲 PCB Format Configuration" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"
                               Foreground="DarkBlue"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Border Background="LightBlue" 
                                CornerRadius="3" 
                                Padding="4,2" 
                                Margin="0,0,8,0">
                            <TextBlock Text="PCB" 
                                       FontSize="9" 
                                       FontWeight="Bold" 
                                       Foreground="DarkBlue"/>
                        </Border>
                        <TextBlock Text="PcbFormatConfig" 
                                   FontWeight="Bold" 
                                   FontSize="13"
                                   Foreground="DarkBlue"/>
                    </StackPanel>
                    <TextBlock Text="{Binding NewPcbFormatConfig.OuterXml}" 
                               FontSize="10" 
                               FontFamily="Consolas"
                               Foreground="DarkSlateGray"
                               TextWrapping="Wrap"
                               Margin="5,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Full XML Preview -->
            <TextBlock Text="📄 Complete XML Preview:" 
                       FontWeight="Bold" FontSize="14" Margin="0,15,0,10"/>

            <Border Background="Black" 
                    BorderBrush="DarkGray" 
                    BorderThickness="2" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="0,0,0,15">
                <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="XmlPreviewTextBox"
                             Foreground="LightGreen" 
                             Background="Black"
                             FontFamily="Consolas"
                             FontSize="11"
                             IsReadOnly="True"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </Border>

            <!-- Instructions -->
            <Border Background="LightYellow" 
                    BorderBrush="Orange" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="💡 Next Steps:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock TextWrapping="Wrap">
                        • Review your configurations and packages above<LineBreak/>
                        • Check the XML preview to ensure everything is correct<LineBreak/>
                        • Click "💾 Save" or "💾 Save As..." to save your configuration<LineBreak/>
                        • Click "🏠 Return to Start" to add more configurations or start a new XML<LineBreak/>
                        • Click "⬅ Back" if you need to make changes to Step 2
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="Blue" FontWeight="SemiBold" 
                       Margin="0,10,0,0" 
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
