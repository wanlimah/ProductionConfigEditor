<Window x:Class="DigitalProductionConfigEditor.Views.EditPcbFormatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit PCB Format Config" 
        Width="700" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="WhiteSmoke">
    <Window.Resources>
        <!-- Bool to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        
        <!-- Style for new island highlighting -->
        <Style x:Key="IslandBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="DarkBlue"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNew}" Value="True">
                    <Setter Property="Background" Value="LightGreen"/>
                    <Setter Property="BorderBrush" Value="Green"/>
                    <Setter Property="BorderThickness" Value="3"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Edit PCB Format Configuration" 
                   FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,15"/>

        <!-- Info Panel -->
        <Border Grid.Row="1" 
                Background="LightBlue" 
                BorderBrush="DarkBlue" 
                BorderThickness="2" 
                Padding="15" 
                Margin="0,0,0,15"
                CornerRadius="5">
            <StackPanel>
                <TextBlock Text="🔲 PCB Format Configuration" 
                           FontWeight="Bold" 
                           FontSize="14"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Configure islands with strip unit counts and panel strip counts" 
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="DarkBlue"/>
            </StackPanel>
        </Border>

        <!-- Islands List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                               Text="Islands:" 
                               FontWeight="SemiBold" 
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    
                    <Button Grid.Column="1"
                            Content="➕ Add Island" 
                            Padding="10,5"
                            Background="LightGreen"
                            Click="OnAddIslandClick"/>
                </Grid>

                <!-- Islands ItemsControl -->
                <ItemsControl x:Name="IslandsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource IslandBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Island Header with Delete Button -->
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="🆕 " 
                                                       FontSize="16"
                                                       Margin="0,0,5,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsNew, Converter={StaticResource BoolToVisConverter}}"
                                                       ToolTip="Newly added island"/>
                                            <TextBlock Text="Island ID:" 
                                                       FontWeight="Bold" 
                                                       FontSize="13"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding Id, Mode=TwoWay}" 
                                                     Width="80"
                                                     VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1"
                                                Content="🗑 Delete" 
                                                Padding="8,4"
                                                Background="LightCoral"
                                                Tag="{Binding}"
                                                Click="OnDeleteIslandClick"/>
                                    </Grid>

                                    <!-- Strip Unit Count -->
                                    <TextBlock Grid.Row="1"
                                               Text="Strip Unit Count:" 
                                               FontWeight="SemiBold"
                                               Margin="0,10,0,5"/>
                                    <Grid Grid.Row="2" Margin="10,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" 
                                                   Text="X:" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding StripUnitX, Mode=TwoWay}"/>
                                        
                                        <TextBlock Grid.Column="3" 
                                                   Text="Y:" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="4" 
                                                 Text="{Binding StripUnitY, Mode=TwoWay}"/>
                                    </Grid>

                                    <!-- Panel Strip Count -->
                                    <TextBlock Grid.Row="3"
                                               Text="Panel Strip Count:" 
                                               FontWeight="SemiBold"
                                               Margin="0,10,0,5"/>
                                    <Grid Grid.Row="4" Margin="10,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" 
                                                   Text="X:" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding PanelStripX, Mode=TwoWay}"/>
                                        
                                        <TextBlock Grid.Column="3" 
                                                   Text="Y:" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="4" 
                                                 Text="{Binding PanelStripY, Mode=TwoWay}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1" 
                    Content="OK" 
                    Width="120" 
                    Height="35"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Background="LightGreen"
                    Click="OnSaveClick"/>
            
            <Button Grid.Column="3" 
                    Content="Cancel" 
                    Width="120" 
                    Height="35"
                    FontSize="13"
                    Click="OnCancelClick"/>
        </Grid>
    </Grid>
</Window>

