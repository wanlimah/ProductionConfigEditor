<UserControl x:Class="DigitalProductionConfigEditor.Views.AdvancedSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    
    <UserControl.Resources>
        <!-- Style for TreeView items -->
        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>
        
        <!-- Style for section headers -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2C3E50" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        
        <!-- Style for attribute labels -->
        <Style x:Key="AttributeLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#34495E" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="150" />
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#F8F9FA">
        <!-- Main Grid Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel: Tree View -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E1E4E8" BorderThickness="0,0,1,0"
                Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="⚙️ Advanced Settings" Style="{StaticResource SectionHeaderStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="Non-standard configurations detected automatically" 
                                       FontSize="11" 
                                       Foreground="#7F8C8D" 
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center" TextAlignment="Center" />
                        </StackPanel>
                        
                        <!-- Help Button -->
                        <Button Grid.Column="1" 
                                Content="❓ Help" 
                                Click="HelpButton_Click"
                                Height="30"
                                Padding="10,5"
                                FontSize="12"
                                Background="LightGoldenrodYellow"
                                BorderBrush="#F39C12"
                                BorderThickness="1"
                                Cursor="Hand"
                                ToolTip="Show Advanced Settings guide" />
                    </Grid>
                </StackPanel>
                
                <!-- Info Banner -->
                <Border Grid.Row="1" Background="#E8F4FD" BorderBrush="#3498DB" BorderThickness="1" 
                        CornerRadius="4" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ℹ️ What's Available Here?" FontWeight="SemiBold" 
                                   Foreground="#2980B9" Margin="0,0,0,5" />
                        <TextBlock Text="Special hardware and test configurations that apply globally to all products. Click any item below to view and edit its settings."
                                   FontSize="11" Foreground="#34495E" TextWrapping="Wrap" Margin="0,0,0,8" />
                        
                        <!-- No Settings Available Message -->
                        <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1" 
                                CornerRadius="3" Padding="8" Margin="0,5,0,0"
                                Visibility="{Binding RootNodes.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}">
                            <TextBlock Text="⚠️ No advanced settings found in Master template"
                                       FontSize="10" Foreground="#856404" TextWrapping="Wrap" />
                        </Border>
                        
                        <!-- Settings Count -->
                        <TextBlock Visibility="{Binding RootNodes.Count, Converter={StaticResource CountToVisibilityConverter}}"
                                   FontSize="10" Foreground="#2980B9" Margin="0,5,0,0">
                            <Run Text="📊 " />
                            <Run Text="{Binding RootNodes.Count, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" configuration(s) available" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                
                <!-- TreeView -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <TreeView x:Name="ConfigTreeView" 
                              ItemsSource="{Binding RootNodes}"
                              SelectedItemChanged="ConfigTreeView_SelectedItemChanged"
                              BorderThickness="0">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource TreeViewItemStyle}">
                                <Setter Property="Padding" Value="5" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2" 
                                            PreviewMouseLeftButtonDown="TreeViewItem_PreviewMouseLeftButtonDown">
                                    <!-- Icon -->
                                    <TextBlock Text="📁" Margin="0,0,5,0" 
                                               Visibility="{Binding Children.Count, Converter={StaticResource CountToVisibilityConverter}}" />
                                    <TextBlock Text="📄" Margin="0,0,5,0"
                                               Visibility="{Binding Children.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}" />
                                    
                                    <!-- Node Name -->
                                    <TextBlock Text="{Binding DisplayName}" 
                                               FontSize="13"
                                               Foreground="#2C3E50" />
                                    
                                    <!-- Attribute Count Badge -->
                                    <Border Background="#3498DB" CornerRadius="8" Padding="5,2"
                                            Margin="8,0,0,0"
                                            Visibility="{Binding HasAttributes, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Attributes.Count, StringFormat='{}{0} attrs'}"
                                                   FontSize="10" 
                                                   Foreground="White"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                      Background="#E1E4E8" />
        
        <!-- Right Panel: Attribute Editor -->
        <Border Grid.Column="2" Background="White" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- No Selection Message -->
                    <Border x:Name="NoSelectionPanel"
                            Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Background="#FFF9E6" 
                            BorderBrush="#F39C12" 
                            BorderThickness="1" 
                            CornerRadius="4" 
                            Padding="20"
                            Margin="0,100,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="👈" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15" />
                            <TextBlock Text="Select a Node" 
                                       FontSize="18" 
                                       FontWeight="SemiBold"
                                       Foreground="#E67E22"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,5" />
                            <TextBlock Text="Choose a configuration node from the tree to view and edit its attributes"
                                       FontSize="12"
                                       Foreground="#7F8C8D"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="300" />
                        </StackPanel>
                    </Border>
                    
                    <!-- Attributes Panel -->
                    <StackPanel x:Name="AttributesPanel"
                                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                        
                        <!-- Header -->
                        <TextBlock Text="{Binding SelectedNode.DisplayName, StringFormat='Edit: {0}'}" 
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,20" />
                        
                        <!-- Attributes List -->
                        <ItemsControl ItemsSource="{Binding SelectedAttributes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" 
                                            BorderBrush="#E1E4E8" 
                                            BorderThickness="1" 
                                            CornerRadius="4"
                                            Padding="15"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Attribute Name -->
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Name}" 
                                                       Style="{StaticResource AttributeLabelStyle}" />
                                            
                                            <!-- Attribute Value Editor -->
                                            <StackPanel Grid.Column="1">
                                                <!-- Dropdown (if options exist) -->
                                                <ComboBox ItemsSource="{Binding Options}"
                                                          SelectedItem="{Binding Value, Mode=TwoWay}"
                                                          Visibility="{Binding HasOptions, Converter={StaticResource BoolToVisibilityConverter}}"
                                                          Height="30"
                                                          FontSize="13"
                                                          Padding="8,5" />
                                                
                                                <!-- TextBox (if no options) -->
                                                <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding HasOptions, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                         Height="30"
                                                         FontSize="13"
                                                         Padding="8,5"
                                                         VerticalContentAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Save Button -->
                        <Button Content="💾 Save Changes" 
                                Click="SaveButton_Click"
                                Height="40"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="#27AE60"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,20,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="20,0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#229954" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

