<UserControl x:Class="DigitalProductionConfigEditor.Views.Step2_EditAttributes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DigitalProductionConfigEditor.Converters">
    <UserControl.Resources>
        <converters:XmlNodeToDisplayConverter x:Key="XmlNodeConverter"/>
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
        <converters:ConfigTypeToVisibilityConverter x:Key="ConfigTypeToVisibilityConverter"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Step 2: Manage Packages" 
                       FontWeight="Bold" FontSize="16" Margin="0,0,0,20"/>
            
            <!-- Configuration Selector -->
            <Border BorderBrush="DodgerBlue" BorderThickness="2" Background="AliceBlue" 
                    Padding="10" Margin="0,0,0,15" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Select Configuration to Edit:" 
                               FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AllEditableConfigurationNodes}" 
                              SelectedItem="{Binding SelectedConfigurationNode, Mode=TwoWay}"
                              Width="500" 
                              HorizontalAlignment="Left"
                              SelectionChanged="Configuration_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="LightGreen" 
                                            CornerRadius="3" 
                                            Padding="4,2" 
                                            Margin="0,0,8,0"
                                            Visibility="{Binding ParentNode.Name, Converter={StaticResource ConfigTypeToVisibilityConverter}, ConverterParameter=ProductionUserConfigs}">
                                        <TextBlock Text="PROD" 
                                                   FontSize="9" 
                                                   FontWeight="Bold" 
                                                   Foreground="DarkGreen"/>
                                    </Border>
                                    <Border Background="PeachPuff" 
                                            CornerRadius="3" 
                                            Padding="4,2" 
                                            Margin="0,0,8,0"
                                            Visibility="{Binding ParentNode.Name, Converter={StaticResource ConfigTypeToVisibilityConverter}, ConverterParameter=DeveloperValidationConfig}">
                                        <TextBlock Text="DEV" 
                                                   FontSize="9" 
                                                   FontWeight="Bold" 
                                                   Foreground="DarkOrange"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ChildNodes.Count, StringFormat='{}{0} package(s)'}" 
                                                   FontSize="10" Foreground="Gray"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Package List Section -->
            <TextBlock Text="Packages in this Configuration:" 
                       FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            
            <!-- Selection Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="☑ Select All" 
                        Width="100" Height="28" 
                        Background="LightBlue"
                        Click="SelectAll_Click"
                        Margin="0,0,5,0"
                        ToolTip="Select all packages"/>
                <Button Content="☐ Deselect All" 
                        Width="100" Height="28" 
                        Background="LightGray"
                        Click="DeselectAll_Click"
                        Margin="0,0,15,0"
                        ToolTip="Deselect all packages"/>
                <Button Content="🗑 Delete Selected" 
                        Width="130" Height="28" 
                        Background="LightCoral"
                        Click="DeleteSelected_Click"
                        ToolTip="Delete all selected packages"/>
            </StackPanel>
            
            <Border BorderBrush="Gray" BorderThickness="1" Background="White" 
                    MaxHeight="350" Margin="0,0,0,15">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PackageItems, FallbackValue={x:Null}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Checkbox for selection -->
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0"
                                                  ToolTip="Select this package"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding PackageName, StringFormat='📦 Package: {0}'}" 
                                                       FontWeight="SemiBold" FontSize="13" Margin="0,0,0,3"
                                                       Foreground="DodgerBlue"/>
                                            <TextBlock Text="{Binding PackageXml}" 
                                                       FontSize="10" Foreground="Gray" 
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✏️ Edit" 
                                                    Width="80" Height="30" 
                                                    Margin="0,0,5,0"
                                                    Click="EditPackage_Click" Tag="{Binding PackageNode}"/>
                                            <Button Content="🗑 Delete" 
                                                    Width="80" Height="30" 
                                                    Background="LightCoral"
                                                    Click="DeletePackage_Click" Tag="{Binding PackageNode}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Add Package Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="➕ Add Single Product" 
                        Width="160" Height="35" 
                        Background="LightGreen"
                        Click="AddPackage_Click"
                        Margin="0,0,10,0"
                        ToolTip="Add one product at a time"/>
                <Button Content="📋 Bulk Add Products" 
                        Width="160" Height="35" 
                        Background="PaleGreen"
                        Click="BulkAddProducts_Click"
                        ToolTip="Add multiple products at once (one per line)"/>
            </StackPanel>

            <!-- Edit Package Section (shown when a package is selected) -->
            <Border BorderBrush="Green" BorderThickness="2" Background="LightGreen" 
                    Padding="10" Margin="0,0,0,15" CornerRadius="5"
                    Visibility="{Binding SelectedPackageNode, Converter={StaticResource NotNullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="📝 Editing Package Attributes" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Package Name: " 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" 
                                 x:Name="PackageNameTextBox"
                                 Text="{Binding SelectedPackageName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 FontWeight="Bold" 
                                 FontSize="13"
                                 MinWidth="300"
                                 CharacterCasing="Upper"/>
                    </Grid>

                    <!-- Dynamic Attributes List -->
                    <ItemsControl ItemsSource="{Binding Attributes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Attribute Name Label -->
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Name, StringFormat='{}{0}:'}" 
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>

                                    <!-- Attribute Value Editor -->
                                    <StackPanel Grid.Column="1">
                                        <!-- TextBox for fields without options -->
                                        <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 CharacterCasing="Upper"
                                                 MinWidth="200">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        
                                        <!-- ComboBox for fields with options -->
                                        <ComboBox ItemsSource="{Binding Options}" 
                                                  SelectedItem="{Binding Value, Mode=TwoWay}"
                                                  MinWidth="200"
                                                  IsEditable="False">
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasOptions}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Instructions -->
            <Border Background="LightYellow" 
                    BorderBrush="Orange" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Padding="10" 
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="💡 Instructions:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock TextWrapping="Wrap">
                        • Use checkboxes to select multiple packages for bulk operations<LineBreak/>
                        • Click "☑ Select All" to select all packages or "☐ Deselect All" to clear selection<LineBreak/>
                        • Click "🗑 Delete Selected" to remove multiple packages at once<LineBreak/>
                        • Click "➕ Add Single Product" to add one product at a time<LineBreak/>
                        • Click "📋 Bulk Add Products" to add multiple products at once (one per line)<LineBreak/>
                        • Click "✏️ Edit" to modify a package's attributes<LineBreak/>
                        • Click "🗑 Delete" to remove a single package<LineBreak/>
                        • Attributes are pre-filled based on existing packages<LineBreak/>
                        • Click "Next" to review changes, then "Save" to persist
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="Blue" FontWeight="SemiBold" 
                       Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
