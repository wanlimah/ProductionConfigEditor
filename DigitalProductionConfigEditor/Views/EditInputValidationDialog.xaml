<Window x:Class="DigitalProductionConfigEditor.Views.EditInputValidationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Input Validation Configs"
        Width="820" Height="680"
        MinWidth="640" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="WhiteSmoke">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Inverted bool-to-visibility: True→Collapsed, False→Visible -->
        <Style x:Key="EntryBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#607D8B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNew}" Value="True">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Setter Property="BorderBrush" Value="#388E3C"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Edit Input Validation Configs"
                   FontSize="17" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Info Panel -->
        <Border Grid.Row="1"
                Background="#FFF8E1"
                BorderBrush="#F9A825"
                BorderThickness="1"
                CornerRadius="5"
                Padding="14,10"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="🔍 Input Validation Configuration"
                           FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#5D4037">
                    <Run>Enter the product tag IDs to validate for Device IDs, Loadboard IDs, and Sublot IDs.</Run>
                    <LineBreak/>
                    <Run>The system validates each entry against a built-in format — invalid IDs are rejected on save.</Run>
                    <LineBreak/>
                    <Run FontWeight="SemiBold" Foreground="#6A1B9A">■ Global</Run>
                    <Run> entries (no Tag) apply to all packages.  </Run>
                    <Run FontWeight="SemiBold" Foreground="#1565C0">■ Per-Package</Run>
                    <Run> entries apply only to the matching package Tag.</Run>
                    <LineBreak/>
                    <Run>Separate multiple values with a semicolon ( ; ).  Example: </Run>
                    <Run FontFamily="Consolas" FontWeight="SemiBold">AFEM-1234-AL;ENGR-5678-ML;AFEM-9012-AC</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- TestConfig entries list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header row with Add buttons -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="TestConfig Entries:"
                               FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="➕ DeviceID Rule"
                            Padding="10,5"
                            Background="#CE93D8"
                            Click="OnAddDeviceIdClick"
                            ToolTip="Add a global ADD_DEVICEID validation rule (applies to all packages)"/>

                    <Button Grid.Column="3"
                            Content="➕ LoadboardID Rule"
                            Padding="10,5"
                            Background="#B2DFDB"
                            Click="OnAddLoadboardClick"
                            ToolTip="Add a global ADD_LOADBOARDID validation rule (applies to all packages)"/>

                    <Button Grid.Column="5"
                            Content="➕ Add Per-Package"
                            Padding="10,5"
                            Background="#90CAF9"
                            Click="OnAddPerPackageClick"
                            ToolTip="Add a per-package ADD_ADDITIONAL_SUBLOTID rule (targeted to a specific package tag)"/>
                </Grid>

                <!-- Entries list -->
                <ItemsControl x:Name="EntriesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource EntryBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Type badges + NEW badge + Delete button -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- GLOBAL badge -->
                                        <Border Grid.Column="0"
                                                Background="#F3E5F5" BorderBrush="#6A1B9A" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
                                                Visibility="{Binding IsGlobal, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="GLOBAL" FontSize="10" FontWeight="Bold" Foreground="#6A1B9A"/>
                                        </Border>

                                        <!-- PER-PACKAGE badge -->
                                        <Border Grid.Column="1"
                                                Background="#E3F2FD" BorderBrush="#1565C0" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
                                                Visibility="{Binding IsPerPackage, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="PER-PACKAGE" FontSize="10" FontWeight="Bold" Foreground="#1565C0"/>
                                        </Border>

                                        <!-- NEW badge -->
                                        <TextBlock Grid.Column="2"
                                                   Text="🆕 NEW"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="Green"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"
                                                   Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Delete button -->
                                        <Button Grid.Column="4"
                                                Content="🗑 Delete"
                                                Padding="7,3"
                                                Background="#FFCDD2"
                                                BorderBrush="#E53935"
                                                Tag="{Binding}"
                                                Click="OnDeleteEntryClick"/>
                                    </Grid>

                                    <!-- Row 1: Config Name (fixed / read-only) -->
                                    <Grid Grid.Row="1" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Name:"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="1"
                                                Background="#ECEFF1"
                                                BorderBrush="#90A4AE"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="8,5"
                                                ToolTip="Config name is fixed and cannot be changed. Use the Add buttons above to create a new entry of the correct type.">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           Foreground="#263238"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="  (fixed)"
                                                           FontSize="10"
                                                           Foreground="#78909C"
                                                           FontStyle="Italic"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Row 2: Tag + Expiry (per-package only) -->
                                    <Grid Grid.Row="2" Margin="0,0,0,6"
                                          Visibility="{Binding IsPerPackage, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Package Tag:"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Tag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 CharacterCasing="Upper"
                                                 ToolTip="Replace this with the real package tag, e.g. AFEM-8282-AP1-RF2  (must not contain XXXX to save)"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="Expiry (YYYY-MM-DD):"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <TextBox Grid.Column="4"
                                                 Text="{Binding Expiry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Optional. Rule is ignored after this date. Format: YYYY-MM-DD"/>
                                    </Grid>

                                    <!-- Row 3: Value (user-entered product tag IDs) -->
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Value:"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Top"
                                                   Margin="0,6,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     CharacterCasing="Upper"
                                                     FontFamily="Consolas"
                                                     ToolTip="{Binding ValueHint}"/>
                                            <TextBlock Text="{Binding ValueHint}"
                                                       FontSize="10"
                                                       Foreground="#78909C"
                                                       FontStyle="Italic"
                                                       TextWrapping="Wrap"
                                                       Margin="2,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- OK / Cancel buttons -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="OK"
                    Width="120" Height="34"
                    FontSize="13" FontWeight="SemiBold"
                    Background="LightGreen"
                    Click="OnSaveClick"/>

            <Button Grid.Column="3"
                    Content="Cancel"
                    Width="120" Height="34"
                    FontSize="13"
                    Click="OnCancelClick"/>
        </Grid>
    </Grid>
</Window>
