<Window x:Class="DigitalProductionConfigEditor.Views.EditDcContactModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit DC Contact Mode Setting Overwrite"
        Width="900" Height="620"
        MinWidth="640" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="WhiteSmoke">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Edit DC Contact Mode Setting Overwrite"
                   FontSize="17" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Info Panel -->
        <Border Grid.Row="1"
                Background="#FFF3E0"
                BorderBrush="#E65100"
                BorderThickness="1"
                CornerRadius="5"
                Padding="14,10"
                Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="⚡ DC Contact Mode Setting Overwrite"
                           FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#BF360C">
                    <Run>Define per-pin electrical parameters for DC Open/Short contact testing.</Run>
                    <LineBreak/>
                    <Run FontWeight="SemiBold">FORCEV pins</Run><Run> (Vdd, Vbatt, Vcc): use VSet, ISet, HighLimit.</Run>
                    <LineBreak/>
                    <Run FontWeight="SemiBold">FORCEI pins</Run><Run> (Vio, SCLK, SDATA): use VSetHi, VSetLo, ISource, ILevel, HighLimit, LowLimit.</Run>
                    <LineBreak/>
                    <Run>Leave unused attributes blank — only populated attributes are written to XML.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Delayms row -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Delay (ms):"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     x:Name="DelaymsBox"
                     FontFamily="Consolas"
                     ToolTip="Delayms Value — pause in milliseconds between contact and measurement"/>
            <TextBlock Grid.Column="2"
                       Text="Milliseconds pause between contact and measurement"
                       FontSize="10" Foreground="#78909C" FontStyle="Italic"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- Pin entries list -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Header row -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Pin Entries:"
                               FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="➕ Add Pin"
                            Padding="10,5"
                            Background="#FFCCBC"
                            Click="OnAddPinClick"
                            ToolTip="Add a new Pin entry"/>
                </Grid>

                <!-- Column headers -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Pin Name"     FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="TestMode"     FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="2" Text="VSet"         FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="3" Text="VSetHi"       FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="4" Text="VSetLo"       FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="5" Text="ISet/ISource" FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="6" Text="ILevel"       FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="7" Text="HighLimit"    FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock Grid.Column="8" Text="LowLimit"     FontWeight="SemiBold" FontSize="11"/>
                </Grid>

                <ItemsControl x:Name="PinItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#90A4AE" BorderThickness="1"
                                    Background="White" CornerRadius="3"
                                    Padding="6,5" Margin="0,3,0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Text="{Binding Name,     Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="Pin name, e.g. Vdd"/>
                                    <ComboBox Grid.Column="1" SelectedItem="{Binding TestMode, Mode=TwoWay}" ItemsSource="{Binding TestModeOptions}" FontSize="11" Margin="0,0,4,0"/>
                                    <TextBox Grid.Column="2" Text="{Binding VSet,     Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="Force voltage (FORCEV only)"/>
                                    <TextBox Grid.Column="3" Text="{Binding VSetHi,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="High voltage limit (FORCEI only)"/>
                                    <TextBox Grid.Column="4" Text="{Binding VSetLo,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="Low voltage limit (FORCEI only)"/>
                                    <TextBox Grid.Column="5" Text="{Binding ISetOrSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="ISet (FORCEV) or ISource (FORCEI)"/>
                                    <TextBox Grid.Column="6" Text="{Binding ILevel,   Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="Current compliance (FORCEI only)"/>
                                    <TextBox Grid.Column="7" Text="{Binding HighLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="Upper measurement limit"/>
                                    <TextBox Grid.Column="8" Text="{Binding LowLimit,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="11" Margin="0,0,4,0" ToolTip="Lower measurement limit (FORCEI only)"/>

                                    <Button Grid.Column="9"
                                            Content="🗑"
                                            Padding="5,2"
                                            Background="#FFCDD2"
                                            BorderBrush="#E53935"
                                            Tag="{Binding}"
                                            Click="OnDeletePinClick"
                                            ToolTip="Remove this pin entry"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- OK / Cancel -->
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="OK"
                    Width="120" Height="34"
                    FontSize="13" FontWeight="SemiBold"
                    Background="LightGreen"
                    Click="OnSaveClick"/>

            <Button Grid.Column="3"
                    Content="Cancel"
                    Width="120" Height="34"
                    FontSize="13"
                    Click="OnCancelClick"/>
        </Grid>
    </Grid>
</Window>
