<Window x:Class="DigitalProductionConfigEditor.Views.AddPackageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Package" 
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="WhiteSmoke">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Add New Package to Configuration" 
                   FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,15"/>

        <!-- Configuration Info -->
        <Border Grid.Row="1" 
                Background="AliceBlue" 
                BorderBrush="DodgerBlue" 
                BorderThickness="1" 
                Padding="10" 
                Margin="0,0,0,15"
                CornerRadius="5">
            <TextBlock Text="{Binding ConfigurationName, StringFormat='Adding to: {0}'}" 
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Attributes Section -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Enter Package Details:" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,10"/>

                <!-- Package Name (Required) -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                               Text="Package Name*:" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="DarkRed"/>
                    <TextBox Grid.Column="1" 
                             x:Name="PackageNameTextBox"
                             CharacterCasing="Upper"
                             ToolTip="Enter the product part number (will be auto-converted to UPPERCASE)"/>
                </Grid>

                <!-- Preview -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                               Text="Result:" 
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                    
                    <TextBlock Grid.Column="1" 
                               x:Name="PreviewNameTextBlock" 
                               Text=""
                               FontWeight="Bold" 
                               Foreground="DarkBlue"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Fixed Attributes List (Edit Only) -->
                <TextBlock Text="Attributes (from template):" 
                           FontWeight="SemiBold" 
                           Margin="0,15,0,10"/>
                
                <ItemsControl x:Name="AttributesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="{Binding Key, StringFormat='{}{0}:'}" 
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                
                                <!-- TextBox for regular attributes -->
                                <TextBox Grid.Column="1" 
                                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewTextInput="NumericField_PreviewTextInput"
                                         DataObject.Pasting="NumericField_Pasting"
                                         Tag="{Binding Key}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDropdown}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <!-- ComboBox for 'enable' and other dropdown attributes -->
                                <ComboBox Grid.Column="1" 
                                          ItemsSource="{Binding DropdownOptions}"
                                          SelectedItem="{Binding Value, Mode=TwoWay}"
                                          IsEditable="False"
                                          Loaded="ComboBox_Loaded"
                                          Tag="{Binding Key}">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDropdown}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Help Text -->
                <Border Background="LightYellow" 
                        BorderBrush="Orange" 
                        BorderThickness="1" 
                        Padding="10" 
                        Margin="0,15,0,0"
                        CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="💡 Tips:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap">
                            • Package Name is required (auto-converted to UPPERCASE)<LineBreak/>
                            • Numeric fields (count, sampling, threshold, x, y, minUnitsBeforeTrigger, minPassedYieldTrigger) only accept non-negative integers (no decimals)<LineBreak/>
                            • Attributes are copied from existing packages (you can edit the values)<LineBreak/>
                            • Values for 'enable' are usually TRUE or FALSE<LineBreak/>
                            • Sublot dropdown: 1A–1E, 2A–2E, 3A–3E, 4A–4E, 5A–5E
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button Content="Create Package" 
                    Width="120" Height="35" 
                    Background="LightGreen" 
                    FontWeight="Bold"
                    Click="CreatePackage_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel" 
                    Width="80" Height="35"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>

