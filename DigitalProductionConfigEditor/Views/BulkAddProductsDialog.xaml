<Window x:Class="DigitalProductionConfigEditor.Views.BulkAddProductsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Add Product Names" 
        Width="1000" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="WhiteSmoke">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Text="Bulk Add Product Names to Configuration" 
                   FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,15"/>

        <!-- Configuration Info -->
        <Border Grid.Row="1" 
                Background="AliceBlue" 
                BorderBrush="DodgerBlue" 
                BorderThickness="1" 
                Padding="10" 
                Margin="0,0,0,15"
                CornerRadius="5">
            <StackPanel>
                <TextBlock Text="{Binding ConfigurationName, StringFormat='Adding to: {0}'}" 
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBlock Text="Enter product names below (one per line)" 
                           FontSize="11" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Step 1: Input Panel -->
            <Border Grid.Row="0" 
                    Background="AliceBlue" 
                    BorderBrush="DodgerBlue" 
                    BorderThickness="1" 
                    Padding="10" 
                    Margin="0,0,0,10"
                    CornerRadius="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📝 Step 1: Enter Product Names (one per line)" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="ProductNamesTextBox"
                                 Height="80"
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 ToolTip="Enter product names, one per line. Auto-converted to UPPERCASE." />
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        
                        <Button Content="⚡ Generate Grid" 
                                Width="120" Height="35"
                                Background="LightGreen"
                                FontWeight="Bold"
                                Click="GenerateGrid_Click"
                                ToolTip="Parse product names and create editable grid"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Step 2: Grid Editor -->
            <Border Grid.Row="1" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    Background="White"
                    CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Grid Header -->
                    <Border Grid.Row="0" 
                            Background="SeaGreen" 
                            Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 Step 2: Edit Product Attributes (Grid View)" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="ProductCountTextBlock"
                                       Text=" - 0 products" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid x:Name="ProductsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="True"
                              SelectionMode="Single"
                              AlternatingRowBackground="AliceBlue"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              Margin="5">
                        <DataGrid.Columns>
                            <!-- Product Name Column -->
                            <DataGridTextColumn Header="Product Name" 
                                                Binding="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                Width="200"
                                                IsReadOnly="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="DarkBlue"/>
                                        <Setter Property="Padding" Value="5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <!-- Dynamic Attribute Columns will be added programmatically -->
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Help Instructions -->
        <Border Grid.Row="3" 
                Background="LightCyan" 
                BorderBrush="DodgerBlue" 
                BorderThickness="1" 
                Padding="10" 
                Margin="0,15,0,0"
                CornerRadius="5">
            <StackPanel>
                <TextBlock Text="💡 How to Use:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock TextWrapping="Wrap" FontSize="11">
                    1. Enter product names in the text box (one per line) - names auto-convert to UPPERCASE<LineBreak/>
                    2. Click "Generate Grid" to create the editable table<LineBreak/>
                    3. Edit attributes for each product individually in the grid<LineBreak/>
                    4. Dropdown columns (light blue header with ▼) allow selection from list<LineBreak/>
                    5. Delete unwanted rows using Delete key or right-click menu<LineBreak/>
                    6. Integer columns (e.g. count, minUnitsBeforeTrigger, minPassedYieldTrigger) accept digits only<LineBreak/>
                    7. Click "Add All Products" to create all packages at once
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button Content="📋 Add All Products" 
                    Width="140" Height="35" 
                    Background="LightGreen" 
                    FontWeight="Bold"
                    Click="AddAllProducts_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel" 
                    Width="80" Height="35"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
