<Window x:Class="DigitalProductionConfigEditor.Views.EditMailConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Mail Config"
        Width="640" Height="340"
        MinWidth="480" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="WhiteSmoke">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Edit Mail Config"
                   FontSize="17" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Info Panel -->
        <Border Grid.Row="1"
                Background="#E3F2FD"
                BorderBrush="#1565C0"
                BorderThickness="1"
                CornerRadius="5"
                Padding="14,10"
                Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="✉ Mail Config"
                           FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="#0D47A1">
                    <Run>Configure the email notification endpoint used by Clotho for automated test reports.</Run>
                    <LineBreak/>
                    <Run FontWeight="SemiBold">RecipientEmail:</Run>
                    <Run> comma-separated list, e.g. alice@broadcom.com,bob@broadcom.com</Run>
                    <LineBreak/>
                    <Run FontWeight="SemiBold">ReplyTo:</Run>
                    <Run> leave empty to use the default noreply address.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Fields -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- APIURL -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="API URL:"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     x:Name="ApiUrlBox"
                     FontFamily="Consolas"
                     ToolTip="The REST endpoint URL for the email queue service"/>

            <!-- RecipientEmail -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Recipient Email:"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Row="2" Grid.Column="1">
                <TextBox x:Name="RecipientEmailBox"
                         FontFamily="Consolas"
                         ToolTip="Comma-separated list of recipient addresses"/>
                <TextBlock Text="Separate multiple addresses with a comma ( , )"
                           FontSize="10" Foreground="#78909C" FontStyle="Italic"
                           Margin="2,3,0,0"/>
            </StackPanel>

            <!-- ReplyTo -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Reply-To:"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Row="4" Grid.Column="1">
                <TextBox x:Name="ReplyToBox"
                         FontFamily="Consolas"
                         ToolTip="Optional reply-to address. Leave empty for default noreply."/>
                <TextBlock Text="Optional — leave empty to use default noreply-clotho.yieldsummary@broadcom.com"
                           FontSize="10" Foreground="#78909C" FontStyle="Italic"
                           Margin="2,3,0,0"/>
            </StackPanel>
        </Grid>

        <!-- OK / Cancel -->
        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="OK"
                    Width="120" Height="34"
                    FontSize="13" FontWeight="SemiBold"
                    Background="LightGreen"
                    Click="OnSaveClick"/>

            <Button Grid.Column="3"
                    Content="Cancel"
                    Width="120" Height="34"
                    FontSize="13"
                    Click="OnCancelClick"/>
        </Grid>
    </Grid>
</Window>
