  <InputValidationConfigs supportedTests="ALL" docRange="InputValidationConfigs">
    <!--
        InputValidationConfigs: Define regex patterns for validating input IDs.

        Two types of TestConfig entries:
        1. GLOBAL  (no 'tag'): applies to all packages.  separator between patterns is semicolon (;).
        2. PER-PACKAGE (with 'tag'): applies only when the loaded package name matches 'tag'.
               Optional 'expiry' attribute (YYYY-MM-DD) disables the rule after that date.

        Common 'name' values:
          ADD_DEVICEID          – regex pattern(s) that a scanned Device ID must match
          ADD_LOADBOARDID       – regex pattern(s) that a scanned Loadboard ID must match
          ADD_ADDITIONAL_SUBLOTID – per-package sublot ID pattern (use 'tag' to target a package)
    -->

    <!-- Global: DeviceID validation
         separator: ;
         example:   AFEM-8227-AS;ENGR-8282-AL
         format:    AFEM/ENGR-####-XX  (4 digits, 2 uppercase letters) -->
    <TestConfig name="ADD_DEVICEID" value=""/>

    <!-- Global: LoadboardID validation
         separator: ;
         example:   LB-RF1-001-001;JP1234;LBSP
         format:    LB-RF1-###-###  or  JP####  or  LBSP... -->
    <TestConfig name="ADD_LOADBOARDID" value=""/>

    <!-- Per-package: Additional Sublot ID validation (add one entry per product package)
         separator: ;
         example:   4A;5B;5C
         format:    [1-5][A-E]  (1 digit + 1 uppercase letter) -->
    <TestConfig tag="AFEM-8282-AP1-RF2"    name="ADD_ADDITIONAL_SUBLOTID" value="" expiry="2026-12-31"/>
    <TestConfig tag="AFEM-8282-AP1-QA-RF2" name="ADD_ADDITIONAL_SUBLOTID" value="" expiry="2026-12-31"/>
    <TestConfig tag="AFEM-8283-AP1-RF2"    name="ADD_ADDITIONAL_SUBLOTID" value="" expiry="2026-12-31"/>
    <TestConfig tag="AFEM-8283-AP1-QA-RF2" name="ADD_ADDITIONAL_SUBLOTID" value="" expiry="2026-12-31"/>
  </InputValidationConfigs>

